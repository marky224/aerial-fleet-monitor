{
  "id": null,
  "uid": "afm-salesforce-health",
  "title": "AFM — Salesforce Health",
  "tags": ["afm", "phase-09"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failed syncs",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_sf_sync_backlog{sync_status=\"failed\"}) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending syncs",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_sf_sync_backlog{sync_status=\"pending\"}) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Synced (total)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_sf_sync_backlog{sync_status=\"synced\"}) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Skipped (gated)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_sf_sync_backlog{sync_status=\"skipped\"}) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Sync backlog by status",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "synced" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "skipped" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_sf_sync_backlog",
          "instant": true,
          "legendFormat": "{{sync_status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sync request rate by handler (5m)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total{handler=~\"/v1/cases/.*sync.*\"}[5m]))",
          "range": true,
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Sync error rate by handler (5m, status≠200)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total{handler=~\"/v1/cases/.*sync.*\",status!=\"200\"}[5m]))",
          "range": true,
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sync p95 latency by handler",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{handler=~\"/v1/cases/.*sync.*\"}[5m])))",
          "range": true,
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Sync requests by handler & status (total)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-BlPu" } },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (handler, status) (http_requests_total{handler=~\"/v1/cases/.*sync.*\"})",
          "instant": true,
          "legendFormat": "{{handler}} · {{status}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Salesforce sync events (Loki)",
      "datasource": { "type": "loki", "uid": "afm-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "afm-loki" },
          "expr": "{service=\"api\"} | json | event=~\"case_sync.*\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
