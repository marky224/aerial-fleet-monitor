{
  "id": null,
  "uid": "afm-case-detector-tuning",
  "title": "AFM — Case Detector Tuning",
  "tags": ["afm", "phase-09"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open cases (total)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_cases)",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Created (last 24h)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_cases_created_24h) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "High severity (open)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_cases{severity=\"high\"}) or vector(0)",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pipeline lag",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_pipeline_lag_seconds",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Open cases by rule (case_type)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-BlPu" } },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_by_type",
          "instant": true,
          "legendFormat": "{{case_type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Open cases by severity",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (severity) (afm_cases)",
          "instant": true,
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Rule × severity",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 11, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": true, "reducer": ["sum"], "fields": ["count"] },
        "sortBy": [{ "displayName": "count", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_by_type_severity",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "indexByName": { "case_type": 0, "severity": 1, "Value": 2 },
            "renameByName": { "case_type": "rule", "severity": "severity", "Value": "count" }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Intake last 24h by rule",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 11, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" } },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_created_24h",
          "instant": true,
          "legendFormat": "{{case_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Open cases by rule over time",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_by_type",
          "range": true,
          "legendFormat": "{{case_type}}"
        }
      ]
    }
  ]
}
