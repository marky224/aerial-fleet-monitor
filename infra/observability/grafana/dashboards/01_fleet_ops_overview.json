{
  "id": null,
  "uid": "afm-fleet-ops-overview",
  "title": "AFM — Fleet Ops Overview",
  "tags": ["afm", "phase-09"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active aircraft (15m)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_active_aircraft",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tracked aircraft (total)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_tracked_aircraft",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pipeline lag",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_pipeline_lag_seconds",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open cases (total)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum(afm_cases)",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Open cases by severity",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (severity) (afm_cases)",
          "instant": true,
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Cases by customer region",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_by_region",
          "instant": true,
          "legendFormat": "{{region}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Salesforce sync backlog",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "synced" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "skipped" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_sf_sync_backlog",
          "instant": true,
          "legendFormat": "{{sync_status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Cases by rule (case_type)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-BlPu" }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "afm_cases_by_type",
          "instant": true,
          "legendFormat": "{{case_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "API request rate by handler (5m)",
      "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "afm-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total[5m]))",
          "range": true,
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Recent API events (Loki)",
      "datasource": { "type": "loki", "uid": "afm-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "afm-loki" },
          "expr": "{service=\"api\"} | json",
          "queryType": "range"
        }
      ]
    }
  ]
}
