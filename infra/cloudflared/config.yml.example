# Cloudflare Tunnel ingress config — example template.
#
# This file IS committed (as .example). The real one (config.yml, no
# .example suffix) is gitignored and lives only on openclaw-pc.
#
# Two ways to drive cloudflared in production:
#   1. Token-only (no config file): docker-compose passes
#      CLOUDFLARE_TUNNEL_TOKEN and the ingress rules are configured in
#      the Cloudflare dashboard. Phase 00 ships with this mode.
#   2. Config-file mode (this template): cloudflared reads ingress rules
#      from a YAML file. Use this when you want ingress rules version-
#      controlled rather than configured in the dashboard.
#
# To switch to config-file mode:
#   1. Copy this to infra/cloudflared/config.yml (no .example suffix)
#      and fill in the tunnel UUID + credentials path.
#   2. Override the `cloudflared` service command in docker-compose to:
#        command: tunnel --config /etc/cloudflared/config.yml run
#      and bind-mount this file plus the credentials JSON into the container.

# UUID of the tunnel, from `cloudflared tunnel create <name>`.
tunnel: 00000000-0000-0000-0000-000000000000

# Path inside the container to the tunnel's credentials JSON.
# Bind-mounted from the host's ~/.cloudflared/<uuid>.json.
credentials-file: /etc/cloudflared/<tunnel-uuid>.json

# Disable autoupdate inside the container — image updates happen via
# `docker compose pull`, not in-place.
no-autoupdate: true

# Ingress rules. cloudflared evaluates these top-down; the catch-all
# `http_status: 404` rule must be last.
#
# Phase 00 exposes only the API. Phase 09 adds grafana.… and optionally
# dagster.… subdomains; Phase 03 adds aerial-fleet-monitor.… (frontend)
# but the frontend is served from CloudFront, not this tunnel.
ingress:
  - hostname: api.aerial-fleet-monitor.markandrewmarquez.com
    service: http://api:8000
    originRequest:
      noTLSVerify: false
      connectTimeout: 30s

  # Phase 09 additions (uncomment when the observability stack lands):
  # - hostname: grafana.aerial-fleet-monitor.markandrewmarquez.com
  #   service: http://grafana:3000
  # - hostname: dagster.aerial-fleet-monitor.markandrewmarquez.com
  #   service: http://dagster-webserver:3000

  # Catch-all — required as the final rule.
  - service: http_status:404
