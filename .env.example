# Aerial Fleet Monitor — environment template
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored. Do not commit secrets.
#
# Variables are grouped by the phase that first introduces them.
# Phase 00 (Foundations) only requires Postgres values to start the local
# stack. Public exposure is handled out-of-stack (see Phase 00 — Public
# API exposure block below) and is optional for local-only development.
# Later phases will pull from this same file.

# ----------------------------------------------------------------------------
# Phase 00 — Postgres (operational store)
# ----------------------------------------------------------------------------
POSTGRES_DB=afm
POSTGRES_USER=afm
POSTGRES_PASSWORD=

# Used by api/ and pipelines/ to reach Postgres from inside the docker network.
# Host `postgres` is the service name in docker-compose.yml.
# Set this to match POSTGRES_PASSWORD above when copying to .env.
# Example: postgresql://afm:<POSTGRES_PASSWORD>@postgres:5432/afm
DATABASE_URL=

# Dagster's internal storage DB. Separate from `afm` so Dagster's tables
# (runs, event_log, schedules, plus its own alembic_version) don't pollute
# AFM's `app` schema. The `dagster` database is created by
# infra/postgres/init.sql on first bring-up.
# Example: postgresql://afm:<POSTGRES_PASSWORD>@postgres:5432/dagster
DAGSTER_DATABASE_URL=

# ----------------------------------------------------------------------------
# Phase 00 — Public API exposure
# ----------------------------------------------------------------------------
# Handled out-of-stack by a host-level reverse tunnel; no env var lives
# in this file. Tooling, hostname, and port are recorded in
# `_private/docs/build/00_foundations.md`.

# ----------------------------------------------------------------------------
# Phase 00 — FastAPI auto-docs gate
# ----------------------------------------------------------------------------
# /docs, /redoc, /openapi.json — disabled by default (secure default).
# Set EXPOSE_DOCS=true only when running locally without public exposure
# (for local Swagger UI), or once Phase 06's JWT auth layer can gate
# the routes.
EXPOSE_DOCS=false

# ----------------------------------------------------------------------------
# Phase 01 — OpenSky Network (live ADS-B positions)
# ----------------------------------------------------------------------------
# Registered free-tier credentials; ~4,000 API credits/day.
# OpenSky migrated from HTTP Basic to OAuth2 client-credentials in 2024–2025.
# Registration issues a client_id (typically `<email>-api-client`) and a
# client_secret on the user's account page. The resource exchanges these at
# OpenSky's Keycloak token endpoint for a short-lived bearer token.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Root directory of the Parquet lakehouse. `/lake` is the in-container
# mount target for the `parquet_lake` Docker volume (see docker-compose.yml).
# Override for host-side `dagster asset materialize` runs.
AFM_LAKE_PATH=/lake

# Historical-baseline backend for delay detection.
# `heuristic` — great-circle distance / cruise-speed ETA. The only backend
#   implemented in Phase 05 (SPEC §3.5 deviation; see build-05 Decisions log).
# `opensky` / `parquet` — future work; selecting them raises NotImplementedError
#   until built (opensky=/flights endpoint; parquet=our own history via DuckDB).
BASELINE_PROVIDER=heuristic

# ----------------------------------------------------------------------------
# Phase 03 — Foundry dashboard sync
# ----------------------------------------------------------------------------
# Base URL the Foundry sync service calls to read AFM API endpoints.
# Foundry tenant URL + service-account credentials are infra-specific and
# live in `_private/foundry/.env` (NOT this file).
AFM_API_BASE=http://localhost:8000

# ----------------------------------------------------------------------------
# Phase 04 — Salesforce (Agentforce DE org)
# ----------------------------------------------------------------------------
SALESFORCE_INSTANCE_URL=https://aerialfleet.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Used by the API to mint scoped session JWTs after the SF OAuth callback.
AFM_JWT_SECRET=
AFM_JWT_ALGORITHM=HS256
AFM_JWT_TTL_SECONDS=86400

# ----------------------------------------------------------------------------
# Phase 05 — Anthropic API (case summaries, METAR plain-English, daily brief)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Haiku-only in v1. Bump the model ID here when a newer Haiku ships;
# no code change required.
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ----------------------------------------------------------------------------
# Phase 08 — Runbook index sync (GitHub → Notion)
# ----------------------------------------------------------------------------
# HMAC signing secret for the /v1/webhooks/github endpoint that triggers
# the runbook_index_sync pipeline on push to main.
GITHUB_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Phase 09 — Grafana (observability stack)
# ----------------------------------------------------------------------------
# Set during Phase 09 stack bring-up; admin password for the Grafana UI.
GRAFANA_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# Phase 11 — Out-of-band notification channels
# ----------------------------------------------------------------------------
# Resend (email) — critical-case alerts.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@alerts.markandrewmarquez.com

# Notion — one-way sync of the markdown runbook library.
NOTION_TOKEN=
NOTION_RUNBOOKS_DATABASE_ID=

# Slack — incoming webhook for case events to an internal-ops workspace.
SLACK_WEBHOOK_URL=
