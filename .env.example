# Aerial Fleet Monitor — environment template
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored. Do not commit secrets.
#
# Variables are grouped by the phase that first introduces them.
# Phase 00 (Foundations) only needs Postgres + Cloudflare set to start the stack.
# Later phases will pull from this same file.

# ----------------------------------------------------------------------------
# Phase 00 — Postgres (operational store)
# ----------------------------------------------------------------------------
POSTGRES_DB=afm
POSTGRES_USER=afm
POSTGRES_PASSWORD=

# Used by api/ and pipelines/ to reach Postgres from inside the docker network.
# Host `postgres` is the service name in docker-compose.yml.
# Set this to match POSTGRES_PASSWORD above when copying to .env.
# Example: postgresql://afm:<POSTGRES_PASSWORD>@postgres:5432/afm
DATABASE_URL=

# ----------------------------------------------------------------------------
# Phase 00 — Cloudflare Tunnel
# ----------------------------------------------------------------------------
# Token issued when you create the tunnel in the Cloudflare dashboard.
# Without this the `cloudflared` container will fail to start.
CLOUDFLARE_TUNNEL_TOKEN=

# ----------------------------------------------------------------------------
# Phase 01 — OpenSky Network (live ADS-B positions)
# ----------------------------------------------------------------------------
# Registered-tier credentials; the free tier gives ~4,000 daily credits.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Switch between historical-baseline backends for delay detection.
# `opensky` uses the OpenSky /flights endpoint (default at launch).
# `parquet` uses our own Parquet history via DuckDB once ≥30 days exist.
BASELINE_PROVIDER=opensky

# ----------------------------------------------------------------------------
# Phase 03 — Frontend (Vite build-time vars)
# ----------------------------------------------------------------------------
# Base URL the React app calls. Local dev points at the dockerized API;
# the production build points at the Cloudflare-tunnel hostname.
VITE_API_BASE_URL=http://localhost:8000

# ArcGIS Maps SDK API key. Free Developer tier covers expected portfolio load.
VITE_ARCGIS_API_KEY=

# ----------------------------------------------------------------------------
# Phase 04 — Salesforce (Agentforce DE org)
# ----------------------------------------------------------------------------
SALESFORCE_INSTANCE_URL=https://aerialfleet.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Used by the API to mint scoped session JWTs after the SF OAuth callback.
AFM_JWT_SECRET=
AFM_JWT_ALGORITHM=HS256
AFM_JWT_TTL_SECONDS=86400

# ----------------------------------------------------------------------------
# Phase 05 — Anthropic API (case summaries, METAR plain-English, daily brief)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Haiku-only in v1. Bump the model ID here when a newer Haiku ships;
# no code change required.
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ----------------------------------------------------------------------------
# Phase 08 — Runbook index sync (GitHub → Notion)
# ----------------------------------------------------------------------------
# HMAC signing secret for the /v1/webhooks/github endpoint that triggers
# the runbook_index_sync pipeline on push to main.
GITHUB_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Phase 09 — Grafana (observability stack)
# ----------------------------------------------------------------------------
# Set during Phase 09 stack bring-up; admin password for the Grafana UI.
GRAFANA_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# Phase 11 — Out-of-band notification channels
# ----------------------------------------------------------------------------
# Resend (email) — critical-case alerts.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@alerts.markandrewmarquez.com

# Notion — one-way sync of the markdown runbook library.
NOTION_TOKEN=
NOTION_RUNBOOKS_DATABASE_ID=

# Slack — incoming webhook for case events to an internal-ops workspace.
SLACK_WEBHOOK_URL=
