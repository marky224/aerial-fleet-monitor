<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Cases per Site (30d)</name>
    <description>AFM Cases created in the last 30 days grouped by AFM_Site_Icao__c. Identifies which watched airports are generating the most operational anomalies.</description>
    <reportType>CaseList</reportType>
    <format>Summary</format>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <groupingsDown>
        <field>Case.AFM_Site_Icao__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>Case.CaseNumber</field>
    </columns>
    <columns>
        <field>Case.Subject</field>
    </columns>
    <columns>
        <field>Case.AFM_Case_Type__c</field>
    </columns>
    <columns>
        <field>Case.Priority</field>
    </columns>
    <columns>
        <field>Case.Status</field>
    </columns>
    <columns>
        <field>Case.AFM_Flight_Id__c</field>
    </columns>
    <columns>
        <field>Case.CreatedDate</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Case.AFM_External_Id__c</column>
            <operator>notEqual</operator>
            <value></value>
        </criteriaItems>
    </filter>
    <timeFrameFilter>
            <dateColumn>CREATED_DATE</dateColumn>
            <interval>INTERVAL_LAST30</interval>
        </timeFrameFilter>
</Report>
