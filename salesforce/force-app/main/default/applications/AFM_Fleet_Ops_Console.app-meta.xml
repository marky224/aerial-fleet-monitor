<?xml version="1.0" encoding="UTF-8"?>
<CustomApplication xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AFM Fleet Ops Console</label>
    <description>Internal-ops Lightning Console for AFM-detected Cases. Separate from the customer-facing AFM (Standard nav) app so customer PSes are unaffected.</description>
    <navType>Console</navType>
    <uiType>Lightning</uiType>
    <formFactors>Large</formFactors>
    <tabs>standard-Case</tabs>
    <tabs>AFM_Site__c</tabs>
    <tabs>AFM_Flight__c</tabs>
    <tabs>standard-report</tabs>
    <tabs>standard-Dashboard</tabs>
    <workspaceConfig>
        <mappings>
            <tab>standard-Case</tab>
        </mappings>
        <mappings>
            <tab>AFM_Site__c</tab>
        </mappings>
        <mappings>
            <tab>AFM_Flight__c</tab>
        </mappings>
        <mappings>
            <tab>standard-report</tab>
        </mappings>
        <mappings>
            <tab>standard-Dashboard</tab>
        </mappings>
    </workspaceConfig>
</CustomApplication>
