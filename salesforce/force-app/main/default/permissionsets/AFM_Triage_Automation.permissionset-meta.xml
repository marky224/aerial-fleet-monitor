<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AFM Triage Automation</label>
    <description>Runs AFM_TriageCase / AFM_CaseTriageService and creates their Tasks; grants read on Case + the AFM fields triage queries. Apex-class access is the #1 agent silent-fail cause. Assigned to the agent user in Phase-07 Group D.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>AFM_CaseTriageService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AFM_TriageCase</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <objectPermissions>
        <object>Task</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Case</object>
        <allowCreate>false</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Case.AFM_Case_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.AFM_Customer_Region__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.AFM_Detection_Facts__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.AFM_External_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.AFM_Flight_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.AFM_Site_Icao__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
