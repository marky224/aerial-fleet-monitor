/**
 * AFM_TriageNarrative — Surface 1 GenAI step (Phase-07 Group C).
 *
 * After deterministic triage (AFM_CaseTriageService) runs on Case insert, this
 * asynchronously generates a {justification, narrative} pair per Case via the
 * Salesforce Models API (aiplatform.ModelsAPI) and writes:
 *   - justification -> Case.AFM_Severity_Justification__c
 *   - narrative     -> the "Customer notification — …" Task body (region-scoped only)
 *
 * The GenAI call sits behind the AFM_GenAiClient seam so tests inject a fake (no
 * real callout). Fully CLI-deployable — no Prompt Builder / GenAiPromptTemplate.
 */
public with sharing class AFM_TriageNarrative {

    @TestVisible
    private static AFM_GenAiClient client = new ModelsApiClient();

    private static final String MODEL = 'sfdc_ai__DefaultOpenAIGPT4OmniMini';
    private static final Integer CHUNK_SIZE = 10;     // callouts per Worker (well under the 100 limit)
    private static final Integer MAX_JOBS = 50;   // System.enqueueJob cap per transaction
    private static final String NOTIF_PREFIX = 'Customer notification — ';
    private static final String NARRATIVE_PLACEHOLDER = '[Narrative pending — generated by triage.]';

    /** Seam so tests can substitute the LLM. */
    public interface AFM_GenAiClient {
        String complete(String prompt);
    }

    /** Enqueue GenAI narrative generation for the given cases — chunked + bounded. */
    public static void enqueue(Set<Id> caseIds) {
        if (caseIds == null || caseIds.isEmpty()) {
            return;
        }
        List<Id> ids = new List<Id>(caseIds);
        Integer total = ids.size();
        Integer jobs = 0;
        Integer i = 0;
        while (i < total && jobs < MAX_JOBS) {
            Set<Id> chunk = new Set<Id>();
            Integer last = i + CHUNK_SIZE;
            if (last > total) {
                last = total;
            }
            for (Integer k = i; k < last; k++) {
                chunk.add(ids[k]);
            }
            System.enqueueJob(new Worker(chunk));
            jobs++;
            i += CHUNK_SIZE;
        }
        Integer processed = jobs * CHUNK_SIZE;
        if (total > processed) {
            System.debug(LoggingLevel.WARN, 'AFM_TriageNarrative: '
                + (total - processed) + ' cases exceeded the per-insert GenAI cap.');
        }
    }

    public class Worker implements Queueable, Database.AllowsCallouts {
        private Set<Id> caseIds;
        public Worker(Set<Id> caseIds) { this.caseIds = caseIds; }

        public void execute(QueueableContext ctx) {
            Map<Id, Case> casesById = new Map<Id, Case>([
                SELECT Id, Subject, AFM_Case_Type__c, AFM_Customer_Region__c, AFM_Site_Icao__c,
                       AFM_Detection_Facts__c, AFM_External_Id__c, AFM_Severity_Justification__c
                FROM Case WHERE Id IN :caseIds
            ]);
            if (casesById.isEmpty()) {
                return;
            }

            Map<Id, Task> notifByCase = new Map<Id, Task>();
            for (Task t : [
                SELECT Id, WhatId, Description FROM Task
                WHERE WhatId IN :caseIds AND Subject LIKE :(NOTIF_PREFIX + '%')
            ]) {
                notifByCase.put(t.WhatId, t);
            }

            List<Case> caseUpdates = new List<Case>();
            List<Task> taskUpdates = new List<Task>();

            for (Case c : casesById.values()) {
                Map<String, String> out;
                try {
                    out = parse(client.complete(buildPrompt(c)));
                } catch (Exception e) {
                    // Leave this case's justification null for a later pass; never block the others.
                    System.debug(LoggingLevel.ERROR, 'AFM_TriageNarrative GenAI failed for '
                        + c.AFM_External_Id__c + ': ' + e.getMessage());
                    continue;
                }

                String justification = out.get('justification');
                if (String.isNotBlank(justification)) {
                    caseUpdates.add(new Case(
                        Id = c.Id,
                        AFM_Severity_Justification__c = justification.abbreviate(4096)
                    ));
                }

                String narrative = out.get('narrative');
                Task notif = notifByCase.get(c.Id);
                if (notif != null && String.isNotBlank(narrative)) {
                    taskUpdates.add(new Task(
                        Id = notif.Id,
                        Description = mergeNarrative(notif.Description, narrative).abbreviate(32000)
                    ));
                }
            }

            if (!caseUpdates.isEmpty()) {
                Database.update(caseUpdates, false);
            }
            if (!taskUpdates.isEmpty()) {
                Database.update(taskUpdates, false);
            }
        }
    }

    // ---- prompt + parse ----------------------------------------------------

    /** Whitelisted scalar facts only (no raw JSON) -> a compact labelled prompt. */
    @TestVisible
    private static String buildPrompt(Case c) {
        List<String> facts = new List<String>();
        if (String.isNotBlank(c.AFM_Detection_Facts__c)) {
            try {
                Map<String, Object> m =
                    (Map<String, Object>) JSON.deserializeUntyped(c.AFM_Detection_Facts__c);
                for (String k : m.keySet()) {
                    Object v = m.get(k);
                    if (v == null || v instanceof Map<String, Object> || v instanceof List<Object>) {
                        continue;   // scalars only — keeps untrusted structure out of the prompt
                    }
                    facts.add('- ' + k + ': ' + String.valueOf(v));
                }
            } catch (Exception e) {
                // unparseable facts -> none
            }
        }
        return 'You are a fleet operations analyst for an aviation monitoring service. '
            + 'An anomaly case was detected. Respond with ONLY a JSON object of the form '
            + '{"justification":"...","narrative":"..."} and nothing else.\n'
            + '- justification: 1-2 sentences for internal ops staff explaining the severity rationale.\n'
            + '- narrative: 2-3 sentences, professional and customer-facing, about the operational impact.\n'
            + 'Do not invent facts beyond those provided.\n\n'
            + 'Case type: ' + emptyDash(c.AFM_Case_Type__c) + '\n'
            + 'Site (ICAO): ' + emptyDash(c.AFM_Site_Icao__c) + '\n'
            + 'Customer region: ' + emptyDash(c.AFM_Customer_Region__c) + '\n'
            + 'Facts:\n' + (facts.isEmpty() ? '- (none)' : String.join(facts, '\n'));
    }

    /** Parse the model's JSON; tolerate ```json fences; fall back to raw-as-justification. */
    @TestVisible
    private static Map<String, String> parse(String raw) {
        Map<String, String> result = new Map<String, String>{ 'justification' => null, 'narrative' => null };
        if (String.isBlank(raw)) {
            return result;
        }
        String s = raw.trim();
        if (s.startsWith('```')) {
            s = s.replaceFirst('^```[a-zA-Z]*\\s*', '').replaceFirst('\\s*```$', '').trim();
        }
        try {
            Map<String, Object> m = (Map<String, Object>) JSON.deserializeUntyped(s);
            if (m.get('justification') != null) {
                result.put('justification', String.valueOf(m.get('justification')));
            }
            if (m.get('narrative') != null) {
                result.put('narrative', String.valueOf(m.get('narrative')));
            }
        } catch (Exception e) {
            result.put('justification', s);   // not JSON -> safe fallback
        }
        return result;
    }

    private static String mergeNarrative(String description, String narrative) {
        if (String.isBlank(description)) {
            return narrative;
        }
        if (description.contains(NARRATIVE_PLACEHOLDER)) {
            return description.replace(NARRATIVE_PLACEHOLDER, narrative);
        }
        return description + '\n\n' + narrative;
    }

    private static String emptyDash(String v) {
        return String.isBlank(v) ? '—' : v;
    }

    // ---- real Models API client (the only seam not exercised by tests) -----

    public class ModelsApiClient implements AFM_GenAiClient {
        public String complete(String prompt) {
            aiplatform.ModelsAPI_ChatMessageRequest msg = new aiplatform.ModelsAPI_ChatMessageRequest();
            msg.role = 'user';
            msg.content = prompt;
            aiplatform.ModelsAPI_ChatGenerationsRequest body = new aiplatform.ModelsAPI_ChatGenerationsRequest();
            body.messages = new List<aiplatform.ModelsAPI_ChatMessageRequest>{ msg };
            aiplatform.ModelsAPI.createChatGenerations_Request req =
                new aiplatform.ModelsAPI.createChatGenerations_Request();
            req.modelName = MODEL;
            req.body = body;
            aiplatform.ModelsAPI.createChatGenerations_Response resp =
                new aiplatform.ModelsAPI().createChatGenerations(req);
            return resp.Code200.generationDetails.generations[0].content;
        }
    }
}
