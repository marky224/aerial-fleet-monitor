/**
 * Tests for AFM_TriageNarrative + AFM_CaseTrigger/Handler (Phase-07 Group C).
 *
 * The Models API call is replaced with an injected fake (AFM_GenAiClient), so the
 * full Surface-1 path — insert -> trigger -> deterministic triage -> async GenAI
 * Worker -> Case/Task writes — runs deterministically with no real callout.
 */
@IsTest
private class AFM_TriageNarrative_Test {

    private static final String NOTIF_PREFIX = 'Customer notification — ';
    private static final String PLACEHOLDER = '[Narrative pending — generated by triage.]';

    /** Canned-response stand-in for the Models API. */
    private class FakeGenAi implements AFM_TriageNarrative.AFM_GenAiClient {
        private String response;
        FakeGenAi(String response) { this.response = response; }
        public String complete(String prompt) { return response; }
    }

    private static String json(String justification, String narrative) {
        return JSON.serialize(new Map<String, String>{
            'justification' => justification, 'narrative' => narrative
        });
    }

    // ---- full auto-triage path ---------------------------------------------

    @IsTest
    static void autoTriage_fillsJustificationAndNarrative() {
        AFM_TriageNarrative.client = new FakeGenAi(json('SEV_JUSTIFY', 'CUST_NARRATE'));

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase(
            'lost_signal', 'East', AFM_TestDataFactory.lostSignalFacts(45, 35000));
        Test.stopTest();   // the enqueued GenAI Worker runs here

        Case got = [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id];
        System.assertEquals('SEV_JUSTIFY', got.AFM_Severity_Justification__c,
            'GenAI justification written to the Case');

        List<Task> notif = [
            SELECT Description FROM Task
            WHERE WhatId = :c.Id AND Subject LIKE :(NOTIF_PREFIX + '%')
        ];
        System.assertEquals(1, notif.size(), 'Region-scoped case has a notification Task');
        System.assert(notif[0].Description.contains('CUST_NARRATE'), 'Narrative merged into the Task body');
        System.assert(!notif[0].Description.contains(PLACEHOLDER), 'Placeholder replaced');

        // The trigger also ran deterministic triage.
        Integer investigations = [
            SELECT COUNT() FROM Task
            WHERE WhatId = :c.Id AND Priority = 'Normal' AND (NOT Subject LIKE :(NOTIF_PREFIX + '%'))
        ];
        System.assert(investigations > 0, 'Deterministic investigation tasks also created');
    }

    @IsTest
    static void allRegion_fillsJustificationOnly() {
        AFM_TriageNarrative.client = new FakeGenAi(json('SEV_JUSTIFY', 'CUST_NARRATE'));

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase('weather_impact', 'All', null);
        Test.stopTest();

        Case got = [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id];
        System.assertEquals('SEV_JUSTIFY', got.AFM_Severity_Justification__c, 'Justification still written');
        System.assertEquals(0, [
            SELECT COUNT() FROM Task WHERE WhatId = :c.Id AND Subject LIKE :(NOTIF_PREFIX + '%')
        ], 'Region All -> no notification Task to narrate');
    }

    @IsTest
    static void fencedJsonResponse_parsed() {
        AFM_TriageNarrative.client = new FakeGenAi(
            '```json\n' + json('FENCED_JUSTIFY', 'N') + '\n```');

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase('go_around', 'All', null);
        Test.stopTest();

        System.assertEquals('FENCED_JUSTIFY',
            [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id].AFM_Severity_Justification__c,
            'A ```json fenced response is unwrapped and parsed');
    }

    @IsTest
    static void nonJsonResponse_fallsBackToJustification() {
        AFM_TriageNarrative.client = new FakeGenAi('Plain prose, not JSON at all.');

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase('delay', 'All', null);
        Test.stopTest();

        System.assertEquals('Plain prose, not JSON at all.',
            [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id].AFM_Severity_Justification__c,
            'Non-JSON response is used verbatim as the justification');
    }

    // ---- trigger eligibility + bypass --------------------------------------

    @IsTest
    static void ineligibleNullCaseType_noAutoTriage() {
        AFM_TriageNarrative.client = new FakeGenAi(json('J', 'N'));

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase(null, 'East', null);
        Test.stopTest();

        System.assertEquals(null,
            [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id].AFM_Severity_Justification__c,
            'No case type -> trigger skips -> no justification');
        System.assertEquals(0, [SELECT COUNT() FROM Task WHERE WhatId = :c.Id],
            'No case type -> no tasks');
    }

    @IsTest
    static void bypass_skipsAutoTriage() {
        AFM_CaseTriggerHandler.bypass = true;
        AFM_TriageNarrative.client = new FakeGenAi(json('J', 'N'));

        Test.startTest();
        Case c = AFM_TestDataFactory.insertFleetOpsCase(
            'lost_signal', 'East', AFM_TestDataFactory.lostSignalFacts(45, 35000));
        Test.stopTest();

        System.assertEquals(null,
            [SELECT AFM_Severity_Justification__c FROM Case WHERE Id = :c.Id].AFM_Severity_Justification__c,
            'Bypass -> trigger no-ops');
        System.assertEquals(0, [SELECT COUNT() FROM Task WHERE WhatId = :c.Id], 'Bypass -> no tasks');
    }

    // ---- prompt + parse units ----------------------------------------------

    @IsTest
    static void buildPrompt_includesTypeAndScalarFactsOnly() {
        Case c = new Case(
            AFM_Case_Type__c = 'lost_signal',
            AFM_Site_Icao__c = 'KORD',
            AFM_Customer_Region__c = 'East',
            AFM_Detection_Facts__c = '{"callsign":"ABC123","gap_minutes":45,"nested":{"x":1},"arr":[1,2]}'
        );
        String prompt = AFM_TriageNarrative.buildPrompt(c);
        System.assert(prompt.contains('Case type: lost_signal'), 'type present');
        System.assert(prompt.contains('KORD') && prompt.contains('East'), 'site + region present');
        System.assert(prompt.contains('callsign: ABC123'), 'scalar fact present');
        System.assert(prompt.contains('gap_minutes: 45'), 'numeric scalar present');
        System.assert(!prompt.contains('- nested:'), 'nested object skipped');
        System.assert(!prompt.contains('- arr:'), 'array skipped');
    }

    @IsTest
    static void buildPrompt_handlesBlankAndUnparseableFacts() {
        System.assert(AFM_TriageNarrative.buildPrompt(new Case(AFM_Case_Type__c = 'delay'))
            .contains('- (none)'), 'blank facts -> (none)');
        System.assert(AFM_TriageNarrative.buildPrompt(
            new Case(AFM_Case_Type__c = 'delay', AFM_Detection_Facts__c = 'not-json'))
            .contains('- (none)'), 'unparseable facts -> (none)');
    }

    @IsTest
    static void parse_variants() {
        Map<String, String> ok = AFM_TriageNarrative.parse(json('J', 'N'));
        System.assertEquals('J', ok.get('justification'));
        System.assertEquals('N', ok.get('narrative'));

        Map<String, String> fenced = AFM_TriageNarrative.parse('```json\n' + json('J2', 'N2') + '\n```');
        System.assertEquals('J2', fenced.get('justification'));
        System.assertEquals('N2', fenced.get('narrative'));

        Map<String, String> raw = AFM_TriageNarrative.parse('hello');
        System.assertEquals('hello', raw.get('justification'));
        System.assertEquals(null, raw.get('narrative'));

        Map<String, String> blank = AFM_TriageNarrative.parse('   ');
        System.assertEquals(null, blank.get('justification'));
        System.assertEquals(null, blank.get('narrative'));
    }

    @IsTest
    static void enqueue_nullAndEmpty_noOp() {
        Test.startTest();
        AFM_TriageNarrative.enqueue(null);
        AFM_TriageNarrative.enqueue(new Set<Id>());
        Test.stopTest();
        System.assertEquals(0, Limits.getAsyncCalls(), 'No jobs enqueued for null/empty input');
    }
}
